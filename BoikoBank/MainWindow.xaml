<Window x:Class="BoikoBank.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BoikoBank"
        Background="Yellow"
        Title="BoikoInternetBank" Height="512" Width="1024">

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="11*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2"
                   Text="Boiko-Bank: Админ-панель" FontWeight="DemiBold"
                   VerticalAlignment="Center" HorizontalAlignment="Center"  Margin="5" Foreground="Black" FontSize="20"/>

        <TextBlock Text="Действия:" Margin="2" Grid.Column="0" Grid.Row="3"
                   VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="DemiBold"/>

        <Button Grid.Row="4" Grid.Column="0" Content="Все записи"
            Command="{Binding NavigationCommand}" CommandParameter="ClientAndTransactions"
            Margin="2" FontSize="10" Foreground="Black" Background="White"/>

        <Button Grid.Row="5" Grid.Column="0" Content="Клиенты"
                Command="{Binding NavigationCommand}" CommandParameter="Clients"
                Margin="2" FontSize="10" Foreground="Black" Background="White"/>

        
        <Button Grid.Row="6" Grid.Column="0" Content="Транзакции"
                Command="{Binding NavigationCommand}" CommandParameter="Transactions"
                Margin="2" FontSize="10" Foreground="Black" Background="White"/>

        <Button Grid.Row="7" Grid.Column="0" Content="Доп фича"
                Command="{Binding NavigationCommand}" CommandParameter="AddTransaction"
                Margin="2" FontSize="10" Foreground="Black" Background="White"/>

        <Button Grid.Row="8" Grid.Column="0" Content="Помощь"
                Command="{Binding NavigationCommand}" CommandParameter="Support"
                Margin="2" FontSize="10" Foreground="Black" Background="White"/>

        <Frame Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5" Grid.RowSpan="15" 
               Content="{Binding CurrentPage}" NavigationUIVisibility="Hidden" Margin="10"/>

        <Image Source="BoikoBankLogo.png" 
               Grid.Row="0" Grid.Column="0" Stretch="Uniform" Height="150" Width="150"
               Grid.ColumnSpan="1" Grid.RowSpan="2" HorizontalAlignment="Center"
               VerticalAlignment="Center" Margin="5"/>
    </Grid>
</Window>