<Window x:Class="BoikoBank.ClientAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BoikoBank"
        mc:Ignorable="d"
        Title="ClientAddWindow" Height="450" Width="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5" Text="Добавление"
                   FontSize="50" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        
        <StackPanel Margin="20" Grid.Column="0" Grid.ColumnSpan="5" Grid.Row="1" Grid.RowSpan="5">
            <TextBlock Text="Имя:" Margin="0,0,0,5"/>
            <TextBox Text="{Binding NewClient.FirstName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>

            <TextBlock Text="Фамилия:" Margin="0,0,0,5"/>
            <TextBox Text="{Binding NewClient.LastName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>
            
            <TextBlock Text="Дата рождения:" Margin="0,0,0,5"/>
            <TextBox Text="{Binding NewClient.DataOfBirth, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>

            <TextBlock Text="Баланс:" Margin="0,0,0,5"/>
            <TextBox Text="{Binding NewClient.Balanse, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>

        </StackPanel>
        <Button Content="Записать" Margin="2,2,2,2" Grid.Column="1" Grid.Row="5" Grid.ColumnSpan="3"
            Command="{Binding SaveClientCommand}" 
            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
            Height="30"/>
    </Grid>
</Window>
