<Page x:Class="BoikoBank.Page3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="История транзакций">
 
    <Grid Background="#F4F4F4">
        <DockPanel Margin="20">
            <TextBlock Text="История банковских операций" DockPanel.Dock="Top" 
                       FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>

            <DataGrid ItemsSource="{Binding TransactionsList}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      SelectionMode="Single"
                      Background="White">

                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Новая транзакция" Command="{Binding AddTransactionCommand}"/>
                        <Separator/>
                        <MenuItem Header="Экспорт в отчет" Command="{Binding ExportCommand}"/>
                        <MenuItem Header="Удалить из истории" 
                                  Foreground="Red"
                                  Command="{Binding DeleteTransactionCommand}" 
                                  CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.SelectedItem}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="*"/>
                    <DataGridTextColumn Header="Тип операции" Binding="{Binding Type}" Width="*"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat={}{0:N2} ₽}" Width="120"/>
                    <DataGridTextColumn Header="Дата и время" Binding="{Binding Date}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</Page>